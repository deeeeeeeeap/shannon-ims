schema_version=1
product=shannon-ims
bundle_scope=application_binary_config_example_runtime_scripts_plugin_sources
release_bundle_runtime_complete=false
target_plugin_build_required=true
runtime_preflight_required=true
default_dataplane=userspace
charon_supervised_by_application=true
exclusive_charon_runtime_required=true
vici_socket_must_be_unowned_before_start=true
strongswan_conf=/etc/strongswan.conf
strongswan_conf_fragment=/etc/strongswan.d/91-vohive-swu.conf
vici_socket=/run/charon.vici
aka_bridge_socket=/run/charon.vohive-aka
pcscf_bridge_socket=/run/charon.vohive-pcscf
required_plugin_vici=libstrongswan-vici.so_or_libcharon-vici.so
required_plugin_eap_aka_method=libstrongswan-eap-aka.so_or_libcharon-eap-aka.so
required_plugin_eap_identity=libstrongswan-eap-identity.so_or_libcharon-eap-identity.so
required_plugin_kernel_netlink=libstrongswan-kernel-netlink.so_or_libcharon-kernel-netlink.so
required_plugin_kernel_libipsec=libstrongswan-kernel-libipsec.so_or_libcharon-kernel-libipsec.so
required_plugin_eap_aka=libstrongswan-eap-aka-vohive.so
required_plugin_p_cscf=libstrongswan-p-cscf-vohive.so
